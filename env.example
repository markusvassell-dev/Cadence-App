DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cadence
DEFAULT_MARKET=health & wellness, underdeveloped and emerging markets

# --- Phase 2: research + uniqueness guard ---
# The Anthropic SDK reads this directly from the environment.
ANTHROPIC_API_KEY=

# Cheaper model for research extraction (per the handoff spec).
RESEARCH_MODEL=claude-haiku-4-5
RESEARCH_TEMPERATURE=0.3

# Pain-point uniqueness guard (token-set ratio): reject above this similarity.
NOVELTY_THRESHOLD=0.70
RESEARCH_MAX_RETRIES=5

# Search/news provider: gdelt (keyless, default) | newsapi | serpapi | fake
SEARCH_PROVIDER=gdelt
SEARCH_MAX_RESULTS=8
# SEARCH_QUERY=          # optional override of the query derived from the market
# SERPAPI_KEY=
# NEWSAPI_KEY=

# --- Phase 3: content generation + hard uniqueness ---
# "claude-sonnet class" model for content, ~0.7 temp per the spec.
CONTENT_MODEL=claude-sonnet-4-6
CONTENT_TEMPERATURE=0.7
CONTENT_MAX_TOKENS=4000
# Cosine threshold for the content_registry uniqueness check. The spec's 0.30
# assumes a semantic 1536-dim embedding model; the shipped lexical HashingEmbedder
# runs higher, so the default is tuned up. Lower toward 0.30 with a semantic Embedder.
CONTENT_SIM_THRESHOLD=0.60
CONTENT_MAX_RETRIES=4

# --- Phase 4: lead capture + ActiveCampaign + email nurture ---
# When AC_BASE_URL + AC_API_TOKEN are set, the real ActiveCampaign v3 client is
# used; otherwise a keyless stub stands in so the lead flow runs in dev.
# AC_BASE_URL=https://<account>.api-us1.com
# AC_API_TOKEN=
# AC_LIST_ID=
# AC_FIELD_LEAD_SOURCE=   # ActiveCampaign custom-field id for lead_source
# AC_FIELD_PAIN_POINT=    # ActiveCampaign custom-field id for pain_point
SENDER_NAME=The Cadence Team

# --- Phase 5: production hardening + real distribution ---
# Retry-with-exponential-backoff for every external call.
RETRY_ATTEMPTS=4
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=16.0
# Optional webhook (e.g. Slack) alerted when a run fails after retries are exhausted.
# ADMIN_ALERT_WEBHOOK=

# Addendum: human approval gate. When true (default), a real run generates + audits
# but holds at status='review' — nothing distributes until a person approves the
# pieces and releases the run. Set false to auto-publish on a clean audit.
HUMAN_APPROVAL_GATE=true

# Real distribution channels (optional; each falls back to a console stub when unset).
# WP_BASE_URL=https://blog.example.com
# WP_USERNAME=
# WP_APP_PASSWORD=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_AUTHOR_URN=urn:li:organization:123456
# FACEBOOK_PAGE_ID=
# FACEBOOK_ACCESS_TOKEN=
# Instagram feed posts need an image + app-reviewed Business creds (text-only stays stub):
# INSTAGRAM_BUSINESS_ID=
# INSTAGRAM_ACCESS_TOKEN=
